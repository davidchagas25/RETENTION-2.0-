# ============================================================
#  RETENTION MVP - variaveis de ambiente
#  Copie este arquivo para ".env" e preencha os valores reais.
#  O sistema roda mesmo sem WhatsApp/IA configurados; esses
#  dois recursos ficam INATIVOS ate as chaves serem preenchidas.
# ============================================================

# --- Servidor ---
PORT=3000
# Segredo usado para assinar os tokens JWT. TROQUE por um valor longo e aleatorio.
JWT_SECRET=troque-este-segredo-por-uma-string-longa-e-aleatoria
# Validade do token de login
JWT_EXPIRES_IN=7d

# --- Usuario administrador inicial (criado no primeiro start, se o banco estiver vazio) ---
ADMIN_NAME=Administrador
ADMIN_EMAIL=admin@retention.local
ADMIN_PASSWORD=admin123

# Preencher o banco com alunos de demonstracao no primeiro start? (true/false)
SEED_DEMO=true

# ============================================================
#  WhatsApp via Twilio
#  Painel: https://console.twilio.com
#  Para testes rapidos use o Sandbox do WhatsApp (Messaging > Try it out)
# ============================================================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Numero remetente no formato: whatsapp:+14155238886 (sandbox) ou seu numero aprovado
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ============================================================
#  IA de retencao via Claude (Anthropic)
#  Chave: https://console.anthropic.com
# ============================================================
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
